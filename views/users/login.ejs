<% layout("/layouts/boilerplate.ejs")%>

<div class="row mt-3 mb-3">
    <h1 class="col-6 offset-2">Login on SafarStay</h1>
  <div class="col-8 offset-2">
    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          name="username"
          id="username"
          type="text"
          class="form-control"
          required
        />
       
      </div>
      
       <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input
          name="password"
          id="password"
          type="password"
          class="form-control"
          required
        />
      
      </div>

      <div class="mb-3">
         <button style="background-color: green;" class="btn btn-dark">Login</button>
      </div>
    </form>
  </div>
</div>
