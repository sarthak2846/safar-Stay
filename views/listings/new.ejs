 <%-layout("/layouts/boilerplate")%>
  <body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          name="listing[title]"
          type="text"
          placeholder="enter title"
          class="form-control"
          required
        />
        <div class="invalid-feedback">
        title is required
      </div>
      </div>
      
      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          name="listing[description]"
          id="ab"
          placeholder="enter description"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">
        Enter the max lenght 45
      </div>
      </div>

     
      <div class="mb-3">
        <label for="image" class="form-label" class="form-label"
          >Upload Image</label
        >
        <input
          name="listing[image]"
          type="file"
          class="form-control"
          required
        />
      </div>
      
      <div class="mb-3">
        <label for="price" class="form-label" class="form-label">Price</label>
        <input
          name="listing[price]"
          placeholder="enter price"
          class="form-control"
          required
        />
        <div class="invalid-feedback">
        Enter a valid Price
      </div>
      </div>

      <div class="row">
         <div class="mb-3 col-md-4">
        <label for="location" class="form-label" class="form-label"
          >Location</label
        >

        <input
          name="listing[location]"
          type="text"
          placeholder="enter  the location"
          class="form-control"
          required
        />
        <div class="invalid-feedback">
        location must be valid
      </div>
      </div>

      <div class="mb-3 col-md-8">
        <label for="country" class="form-label" class="form-label"
          >Country</label
        >
        <input
          name="listing[country]"
          type="text"
          placeholder="enter country"
          class="form-control"
          required
        />
        <div class="invalid-feedback">
        country must be valid
      </div>
      </div>
      <div class="mb-3">
         <button style="background-color: #fe424d;" class="btn btn-dark">ADD</button>
      </div>
      </div>
     

     
    </form>

        </div>
    </div>
    
  </body>
</html>
